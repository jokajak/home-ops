# Template for users.sops.yaml — copy, fill in, then encrypt:
#   cp users.sops.yaml.example users.sops.yaml
#   # edit users.sops.yaml with real values
#   task sops:encrypt file=terraform/authentik/users.sops.yaml
#
# A LIST of users (username is a field, not a map key), so after SOPS encryption EVERY
# value — usernames, names, emails — is opaque in git. Each user:
#   - username: Authentik username
#   - name:     display name
#   - email:    MUST equal the user's GitHub primary email (email_link links the GitHub
#               login to this account)
#   - groups:   optional list of group NAMES (see group_ids_by_name in users.tf);
#               defaults to ["users"]. None of these users are superusers.
#               Use "readers" to grant Grafana read (Viewer) access.
users:
  - username: alice
    name: Alice Example
    email: alice@example.com
    groups:
      - users
      - readers
